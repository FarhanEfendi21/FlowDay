{
  "crons": [
    {
      "path": "/api/notifications/check-deadlines",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/notifications/check-urgent-deadlines",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/notifications/check-habits",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/notifications/cleanup-tokens",
      "schedule": "0 19 * * 6"
    }
  ],
  "headers": [
    {
      "source": "/firebase-messaging-sw.js",
      "headers": [
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
